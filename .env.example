# App
NEXT_PUBLIC_SITE_URL=https://example.com

# Admin authentication
# Generate ADMIN_PASSWORD_HASH with:
# node -e "const { createHash } = require('crypto'); console.log(createHash('sha256').update(process.argv[1]).digest('hex'))" "your-strong-password"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=replace-with-sha256-password-hash
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=replace-me
ANALYTICS_API_KEY=replace-me

# Email provider
EMAIL_PROVIDER=resend
EMAIL_FROM="Arinas <noreply@example.com>"
RESEND_API_KEY=re_replace_me
POSTMARK_SERVER_TOKEN=replace-me
SENDGRID_API_KEY=replace-me

# Optional: restrict admin to specific Supabase user emails (comma-separated).
# If unset, any authenticated Supabase user is treated as admin.
ADMIN_EMAILS=
